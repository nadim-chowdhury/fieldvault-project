# =============================================================================
# FieldVault Monorepo — Universal .gitignore
# Covers: NestJS · Next.js · React Native · Expo · Node.js · TypeScript
# =============================================================================


# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/


# =============================================================================
# BUILD OUTPUTS
# =============================================================================
# NestJS
/apps/api/dist/
/apps/api/build/

# Next.js
/apps/web/.next/
/apps/web/out/
/apps/web/build/

# Expo / React Native
/apps/mobile/dist/
/apps/mobile/web-build/
/apps/mobile/expo-env.d.ts

# Shared packages
/packages/*/dist/
/packages/*/build/


# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging
.env.staging.local
.env.production
.env.production.local
*.env


# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*


# =============================================================================
# TESTING & COVERAGE
# =============================================================================
/coverage
/.nyc_output
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/


# =============================================================================
# TYPESCRIPT
# =============================================================================
*.tsbuildinfo
next-env.d.ts


# =============================================================================
# EXPO & REACT NATIVE
# =============================================================================
# Expo
.expo/

# Native generated folders (EAS builds these — never commit)
/apps/mobile/ios/
/apps/mobile/android/

# Native artifacts
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Metro bundler
.metro-health-check*

# React Native cache
.rn-cache/


# =============================================================================
# NEXT.JS
# =============================================================================
.vercel
/apps/web/.vercel


# =============================================================================
# TURBOREPO
# =============================================================================
.turbo/


# =============================================================================
# IDEs & EDITORS
# =============================================================================
# VSCode (keep shared settings, ignore personal)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Eclipse
.project
.classpath
.c9/
*.launch
.settings/

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist


# =============================================================================
# OS GENERATED
# =============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# =============================================================================
# TEMPORARY FILES
# =============================================================================
.temp/
.tmp/
tmp/
temp/


# =============================================================================
# RUNTIME & PROCESS
# =============================================================================
pids/
*.pid
*.seed
*.pid.lock

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json


# =============================================================================
# SECURITY — NEVER COMMIT THESE
# =============================================================================
*.pem
*.cert
*.key
*.p12
*.pfx
google-service-account.json
service-account*.json
*-service-account.json
firebase-adminsdk*.json
secrets/
.secrets/


# =============================================================================
# DATABASE
# =============================================================================
*.sqlite
*.sqlite3
*.db


# =============================================================================
# DOCKER (local overrides only — keep Dockerfiles)
# =============================================================================
docker-compose.override.yml


# =============================================================================
# MISC
# =============================================================================
app-example/
.cache/
*.tgz
*.zip
*.tar.gz